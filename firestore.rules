rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() {
      // In this environment we will not strictly require email verification, but we should.
      // Wait, Google auth from AI Studio doesn't always have email_verified depending on the setup. Let's still use it unless it fails.
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // Validation Blueprint for Audit
    function isValidAudit(data) {
      return data.keys().hasAll(['namaSPPG', 'alamatSPPG', 'tanggalEvaluasi', 'golongan', 'answers', 'totalPenalty', 'userId', 'createdAt']) &&
             data.namaSPPG is string && data.namaSPPG.size() > 0 && data.namaSPPG.size() <= 500 &&
             data.alamatSPPG is string && data.alamatSPPG.size() <= 1000 &&
             data.tanggalEvaluasi is string && data.tanggalEvaluasi.size() <= 50 &&
             data.golongan is string && data.golongan in ['A', 'B', 'C'] &&
             data.answers is map &&
             data.totalPenalty is number && data.totalPenalty >= 0 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /audits/{auditId} {
      // Allow read if the user owns the document
      allow get: if isSignedIn() && isValidId(auditId) && existing().userId == request.auth.uid;
      
      // Allow list if the query explicitly filters for the user's own documents
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Allow create if all data is valid
      allow create: if isSignedIn() && isValidId(auditId) && isValidAudit(incoming());

      // Audits cannot be updated or deleted to preserve records
      allow update, delete: if false;
    }
  }
}
